<Window x:Class="FeaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="FEA Membranes" Width="1500" Height="950"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Click="MenuNew_Click"/>
                <MenuItem Header="_Open…" Click="MenuOpen_Click" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save" Click="MenuSave_Click" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As…" Click="MenuSaveAs_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Geometry">
                <MenuItem Header="Surface by _Corner Points…" Click="MenuSurfaceByCorners_Click"/>
                <MenuItem Header="Surface by _Picking (4 clicks)" Click="MenuSurfacePick_Click"/>
                <Separator/>
                <MenuItem Header="Edge _Radius (pick edge)…" Click="MenuEdgeRadius_Click"/>
                <Separator/>
                <MenuItem Header="_Delete Selected Surfaces" Click="MenuDeleteSurfaces_Click"/>
            </MenuItem>
            <MenuItem Header="_Mesh">
                <MenuItem Header="_Mesh Selected Surfaces…" Click="MenuMesh_Click"/>
                <MenuItem Header="_Clear Mesh on Selected Surfaces" Click="MenuClearMesh_Click"/>
            </MenuItem>
            <MenuItem Header="M_odel">
                <MenuItem Header="_Constraint on Selected Nodes…" Click="MenuConstraint_Click"/>
                <MenuItem Header="_Load on Selected Nodes…" Click="MenuLoad_Click"/>
                <MenuItem Header="_Enforced Displacement on Selected Nodes…" Click="MenuEnforced_Click"/>
                <MenuItem Header="Remove _BCs from Selected Nodes" Click="MenuClearBc_Click"/>
                <Separator/>
                <MenuItem Header="Create _Bars Along Selected Nodes…" Click="MenuBars_Click"/>
                <MenuItem Header="Create _Spring Between 2 Selected Nodes…" Click="MenuSpring_Click"/>
                <Separator/>
                <MenuItem Header="Surface _Properties…" Click="MenuSurfaceProps_Click"/>
            </MenuItem>
            <MenuItem Header="_Analyze">
                <MenuItem Header="_Solve" Click="BtnSolve_Click" InputGestureText="F5"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Fit" Click="BtnFit_Click" InputGestureText="F"/>
                <MenuItem Header="Zoom _In" Click="MenuZoomIn_Click"/>
                <MenuItem Header="Zoom _Out" Click="MenuZoomOut_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuGrid" Header="_Grid" IsCheckable="True" Click="MenuGrid_Click"/>
                <MenuItem x:Name="MenuLabels" Header="Bar/Spring _Labels" IsCheckable="True" IsChecked="True" Click="MenuLabels_Click"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Click="MenuOpen_Click" Padding="6,3">Open</Button>
                <Button Click="MenuSave_Click" Padding="6,3">Save</Button>
                <Separator/>
                <Button Click="BtnFit_Click" Padding="6,3">Fit</Button>
                <Separator/>
                <Label VerticalAlignment="Center">Select:</Label>
                <ComboBox x:Name="CmbTarget" Width="100" SelectedIndex="0" SelectionChanged="CmbTarget_SelectionChanged">
                    <ComboBoxItem>Surfaces</ComboBoxItem>
                    <ComboBoxItem>Nodes</ComboBoxItem>
                    <ComboBoxItem>Elements</ComboBoxItem>
                    <ComboBoxItem>Bars</ComboBoxItem>
                </ComboBox>
                <Separator/>
                <Button Click="MenuMesh_Click" Padding="6,3">Mesh…</Button>
                <Button Click="MenuConstraint_Click" Padding="6,3">Constraint…</Button>
                <Button Click="MenuLoad_Click" Padding="6,3">Load…</Button>
                <Button Click="MenuBars_Click" Padding="6,3">Bars…</Button>
                <Separator/>
                <Button x:Name="BtnSolve" Click="BtnSolve_Click" Padding="8,3" FontWeight="Bold">Solve</Button>
                <Separator/>
                <Label VerticalAlignment="Center">Contour:</Label>
                <ComboBox x:Name="CmbView" Width="110" SelectionChanged="CmbView_SelectionChanged" SelectedIndex="0">
                    <ComboBoxItem>None</ComboBoxItem>
                    <ComboBoxItem>Von Mises</ComboBoxItem>
                    <ComboBoxItem>Stress X</ComboBoxItem>
                    <ComboBoxItem>Stress Y</ComboBoxItem>
                    <ComboBoxItem>Shear XY</ComboBoxItem>
                </ComboBox>
                <CheckBox x:Name="ChkDeformed" VerticalAlignment="Center" Margin="6,0,0,0"
                          Checked="ChkDeformed_Changed" Unchecked="ChkDeformed_Changed">Deformed</CheckBox>
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="TxtPrompt" Text="Ready." FontWeight="SemiBold"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="TxtSelInfo" Text=""/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TxtCoords" Text=""/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Model Info pane -->
            <DockPanel Grid.Column="0" Background="White">
                <TextBlock DockPanel.Dock="Top" Text="Model Info" FontWeight="Bold" Padding="8,6"
                           Background="#2D3E5F" Foreground="White"/>
                <TreeView x:Name="ModelTree" BorderThickness="0" SelectedItemChanged="ModelTree_SelectedItemChanged"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#C8C8C8"/>

            <!-- Graphics + Messages -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>

                <skia:SKElement x:Name="Canvas" Grid.Row="0"
                                PaintSurface="Canvas_PaintSurface"
                                MouseWheel="Canvas_MouseWheel"
                                MouseDown="Canvas_MouseDown"
                                MouseMove="Canvas_MouseMove"
                                MouseUp="Canvas_MouseUp"/>

                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Background="#C8C8C8"/>

                <DockPanel Grid.Row="2" Background="White">
                    <TextBlock DockPanel.Dock="Top" Text="Messages" FontWeight="Bold" Padding="8,3"
                               Background="#2D3E5F" Foreground="White"/>
                    <TextBox x:Name="TxtMessages" IsReadOnly="True" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"/>
                </DockPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
