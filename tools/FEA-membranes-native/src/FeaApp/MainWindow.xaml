<Window x:Class="FeaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="FEA Membranes (native)" Width="1280" Height="800"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button x:Name="BtnOpen" Click="BtnOpen_Click" Padding="8,3">Open…</Button>
                <Button x:Name="BtnSolve" Click="BtnSolve_Click" Padding="8,3" IsEnabled="False">Solve</Button>
                <Separator/>
                <Button x:Name="BtnFit" Click="BtnFit_Click" Padding="8,3">Fit</Button>
                <Separator/>
                <Label VerticalAlignment="Center">View:</Label>
                <ComboBox x:Name="CmbView" Width="140" SelectionChanged="CmbView_SelectionChanged" SelectedIndex="0">
                    <ComboBoxItem>Mesh</ComboBoxItem>
                    <ComboBoxItem>Von Mises</ComboBoxItem>
                    <ComboBoxItem>Stress X</ComboBoxItem>
                    <ComboBoxItem>Stress Y</ComboBoxItem>
                    <ComboBoxItem>Shear XY</ComboBoxItem>
                </ComboBox>
                <Separator/>
                <CheckBox x:Name="ChkDeformed" VerticalAlignment="Center" Checked="ChkDeformed_Changed" Unchecked="ChkDeformed_Changed">Deformed</CheckBox>
            </ToolBar>
        </ToolBarTray>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="Open a model (.json saved from the FEA-membranes webtool)."/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TxtCoords" Text=""/>
            </StatusBarItem>
        </StatusBar>
        <skia:SKElement x:Name="Canvas"
                        PaintSurface="Canvas_PaintSurface"
                        MouseWheel="Canvas_MouseWheel"
                        MouseDown="Canvas_MouseDown"
                        MouseMove="Canvas_MouseMove"
                        MouseUp="Canvas_MouseUp"/>
    </DockPanel>
</Window>
